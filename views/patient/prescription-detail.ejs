<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="page-header">
    <div class="container">
        <h1><i class="fas fa-file-prescription"></i> Prescription Details</h1>
    </div>
</section>

<section class="section">
    <div class="container">
        <div style="max-width: 800px; margin: 0 auto;">
            <div class="card">
                <div class="card-body">
                    <div class="rx-detail-header">
                        <div class="rx-brand">
                            <h2><i class="fas fa-hospital"></i> IIT Ropar Medical Center</h2>
                            <p>Rupnagar, Punjab - 140001</p>
                        </div>
                        <div class="rx-date">
                            <strong>Date:</strong> <%= new Date(prescription.created_at).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                        </div>
                    </div>
                    <hr>
                    <div class="rx-info-grid">
                        <div>
                            <h4>Patient</h4>
                            <p><strong><%= prescription.patient_name %></strong></p>
                        </div>
                        <div>
                            <h4>Doctor</h4>
                            <p><strong><%= prescription.doctor_name %></strong> (<%= prescription.specialization %>)</p>
                        </div>
                    </div>
                    <hr>
                    <div class="rx-section">
                        <h4><i class="fas fa-diagnoses"></i> Diagnosis</h4>
                        <p><%= prescription.diagnosis %></p>
                    </div>
                    <div class="rx-section">
                        <h4><i class="fas fa-pills"></i> Medicines</h4>
                        <% const meds = typeof prescription.medicines === 'string' ? JSON.parse(prescription.medicines) : prescription.medicines; %>
                        <% if (meds && meds.length > 0) { %>
                            <table class="table">
                                <thead><tr><th>#</th><th>Medicine</th><th>Dosage</th><th>Frequency</th><th>Duration</th></tr></thead>
                                <tbody>
                                    <% meds.forEach((med, i) => { %>
                                        <tr>
                                            <td><%= i + 1 %></td>
                                            <td><strong><%= med.name %></strong></td>
                                            <td><%= med.dosage %></td>
                                            <td><%= med.frequency %></td>
                                            <td><%= med.duration %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        <% } %>
                    </div>
                    <% if (prescription.tests_recommended) { %>
                        <div class="rx-section"><h4><i class="fas fa-vial"></i> Tests</h4><p><%= prescription.tests_recommended %></p></div>
                    <% } %>
                    <% if (prescription.instructions) { %>
                        <div class="rx-section"><h4><i class="fas fa-clipboard-list"></i> Instructions</h4><p><%= prescription.instructions %></p></div>
                    <% } %>
                    <% if (prescription.follow_up_date) { %>
                        <div class="rx-section"><h4><i class="fas fa-calendar-plus"></i> Follow-up</h4><p><%= new Date(prescription.follow_up_date).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %></p></div>
                    <% } %>
                </div>
            </div>
            <div class="form-actions mt-2">
                <a href="/patient/prescriptions" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
                <button onclick="window.print()" class="btn btn-primary"><i class="fas fa-print"></i> Print</button>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
