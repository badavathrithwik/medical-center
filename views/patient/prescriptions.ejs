<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="page-header">
    <div class="container">
        <h1><i class="fas fa-file-prescription"></i> My Prescriptions</h1>
        <p>View all prescriptions issued to you</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <% if (prescriptions && prescriptions.length > 0) { %>
            <% prescriptions.forEach(rx => { %>
                <div class="card mb-1">
                    <div class="card-body">
                        <div class="prescription-row">
                            <div class="rx-main">
                                <h4><%= rx.diagnosis %></h4>
                                <div class="rx-meta">
                                    <span><i class="fas fa-user-md"></i> <%= rx.doctor_name %> (<%= rx.specialization %>)</span>
                                    <span><i class="fas fa-calendar"></i> <%= new Date(rx.created_at).toLocaleDateString('en-IN') %></span>
                                </div>
                                <div class="rx-medicines-inline">
                                    <% const meds = typeof rx.medicines === 'string' ? JSON.parse(rx.medicines) : rx.medicines; %>
                                    <% if (meds && meds.length > 0) { %>
                                        <% meds.forEach(med => { %>
                                            <span class="medicine-tag"><%= med.name %> - <%= med.dosage %></span>
                                        <% }) %>
                                    <% } %>
                                </div>
                                <% if (rx.follow_up_date) { %>
                                    <p class="mt-1"><i class="fas fa-calendar-plus"></i> Follow-up: <%= new Date(rx.follow_up_date).toLocaleDateString('en-IN') %></p>
                                <% } %>
                            </div>
                            <div class="rx-actions">
                                <a href="/patient/prescriptions/<%= rx.id %>" class="btn btn-sm btn-primary"><i class="fas fa-eye"></i> View Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="empty-state">
                <i class="fas fa-file-prescription"></i>
                <h3>No prescriptions yet</h3>
                <p>Your prescriptions will appear here after doctor consultations.</p>
            </div>
        <% } %>
    </div>
</section>

<%- include('../partials/footer') %>
