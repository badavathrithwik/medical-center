<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="page-header">
    <div class="container">
        <h1><i class="fas fa-calendar-plus"></i> Book an Appointment</h1>
        <p>Describe your symptoms and we'll recommend the best doctor for you</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <!-- Step Indicators -->
        <div class="booking-steps">
            <div class="step active" data-step="1">
                <span class="step-num">1</span>
                <span class="step-label">Describe Symptoms</span>
            </div>
            <div class="step-line"></div>
            <div class="step" data-step="2">
                <span class="step-num">2</span>
                <span class="step-label">Choose Doctor</span>
            </div>
            <div class="step-line"></div>
            <div class="step" data-step="3">
                <span class="step-num">3</span>
                <span class="step-label">Select Date & Time</span>
            </div>
            <div class="step-line"></div>
            <div class="step" data-step="4">
                <span class="step-num">4</span>
                <span class="step-label">Confirm Booking</span>
            </div>
        </div>

        <form action="/appointments/book" method="POST" id="bookingForm">
            <!-- STEP 1: Symptom Input -->
            <div class="booking-section" id="step1">
                <h3><i class="fas fa-stethoscope"></i> What are your symptoms?</h3>
                <p class="text-muted">Describe your symptoms in detail — we'll recommend the best doctor for your condition.</p>

                <div class="form-group">
                    <label for="symptomInput"><i class="fas fa-notes-medical"></i> Symptoms Description *</label>
                    <textarea id="symptomInput" class="form-control" rows="4"
                        placeholder="e.g., I have been having a persistent headache and mild fever for the past 3 days. Also experiencing body pain and fatigue..." required></textarea>
                </div>

                <div class="symptom-tags-help">
                    <p class="small text-muted"><i class="fas fa-lightbulb"></i> Quick tags (click to add):</p>
                    <div class="quick-tags">
                        <span class="quick-tag" data-tag="fever">🌡️ Fever</span>
                        <span class="quick-tag" data-tag="headache">🤕 Headache</span>
                        <span class="quick-tag" data-tag="cold and cough">🤧 Cold & Cough</span>
                        <span class="quick-tag" data-tag="body pain">💪 Body Pain</span>
                        <span class="quick-tag" data-tag="stomach pain">🤢 Stomach Pain</span>
                        <span class="quick-tag" data-tag="skin rash">🔴 Skin Rash</span>
                        <span class="quick-tag" data-tag="stress and anxiety">😰 Stress & Anxiety</span>
                        <span class="quick-tag" data-tag="insomnia">😴 Insomnia</span>
                        <span class="quick-tag" data-tag="allergy">🤧 Allergy</span>
                        <span class="quick-tag" data-tag="chronic pain">⚡ Chronic Pain</span>
                        <span class="quick-tag" data-tag="injury">🩹 Injury</span>
                        <span class="quick-tag" data-tag="breathing difficulty">😮‍💨 Breathing Issue</span>
                    </div>
                </div>

                <% if (patientGender === 'Female') { %>
                <div class="form-group" style="margin-top: 16px;">
                    <label class="checkbox-label" style="display:flex; align-items:center; gap:10px; cursor:pointer; padding:8px 14px; background:var(--bg-secondary); border-radius:8px; border: 1px solid var(--border);">
                        <input type="checkbox" id="prefer_female_doctor_check" name="prefer_female_doctor" style="width:18px; height:18px; accent-color:var(--primary);">
                        <span><i class="fas fa-user-md"></i> I prefer to consult a female doctor (if available)</span>
                    </label>
                </div>
                <% } %>

                <button type="button" class="btn btn-primary" id="findDoctorsBtn" style="margin-top: 16px;">
                    <i class="fas fa-search"></i> Find Best Doctor
                </button>
            </div>

            <!-- STEP 2: Doctor Selection -->
            <div class="booking-section hidden" id="step2">
                <h3><i class="fas fa-user-md"></i> Recommended Doctors</h3>
                <p class="text-muted">Based on your symptoms, here are the best matching doctors</p>

                <div id="doctorRecommendations" class="doctor-select-grid">
                    <% if (doctors && doctors.length > 0) { %>
                        <% doctors.forEach(doctor => { %>
                            <label class="doctor-select-card" for="doctor_<%= doctor.id %>">
                                <input type="radio" id="doctor_<%= doctor.id %>" name="doctor_id" value="<%= doctor.id %>"
                                    <%= selectedDoctor == doctor.id ? 'checked' : '' %>
                                    data-doctor-name="<%= doctor.name %>"
                                    data-specialization="<%= doctor.specialization %>"
                                    data-gender="<%= doctor.gender || '' %>"
                                    required>
                                <div class="doctor-select-inner">
                                    <div class="doctor-select-avatar">
                                        <i class="fas fa-user-md"></i>
                                    </div>
                                    <h4><%= doctor.name %></h4>
                                    <span class="badge badge-primary"><%= doctor.specialization %></span>
                                    <p class="small"><%= doctor.qualification %></p>
                                    <p class="small text-muted"><%= doctor.experience_years %> years experience</p>
                                    <% if (doctor.gender) { %>
                                        <p class="small text-muted"><i class="fas fa-<%= doctor.gender === 'Female' ? 'venus' : 'mars' %>"></i> <%= doctor.gender %></p>
                                    <% } %>
                                </div>
                                <div class="doctor-select-check">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                            </label>
                        <% }) %>
                    <% } %>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-outline" id="backToStep1">
                        <i class="fas fa-arrow-left"></i> Back
                    </button>
                    <button type="button" class="btn btn-primary" id="toStep3" disabled>
                        Next: Select Date & Time <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </div>

            <!-- STEP 3: Date & Slot Selection -->
            <div class="booking-section hidden" id="step3">
                <h3>Select Date & Time Slot</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label for="appointment_date"><i class="fas fa-calendar"></i> Appointment Date</label>
                        <input type="date" id="appointment_date" name="appointment_date" class="form-control" required
                            min="<%= new Date().toISOString().split('T')[0] %>">
                    </div>
                </div>

                <div id="slotsContainer" class="slots-container">
                    <div class="empty-state small-state">
                        <i class="fas fa-calendar-day"></i>
                        <p>Select a date to see available time slots</p>
                    </div>
                </div>

                <input type="hidden" id="slot_id" name="slot_id" required>
                <input type="hidden" id="symptoms_hidden" name="symptoms">

                <div class="form-actions">
                    <button type="button" class="btn btn-outline" id="backToStep2">
                        <i class="fas fa-arrow-left"></i> Back
                    </button>
                    <button type="button" class="btn btn-primary" id="toStep4" disabled>
                        Next: Confirm Details <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </div>

            <!-- STEP 4: Confirmation -->
            <div class="booking-section hidden" id="step4">
                <h3><i class="fas fa-clipboard-check"></i> Review & Confirm Booking</h3>

                <div class="booking-summary" id="bookingSummary">
                    <!-- Filled dynamically -->
                </div>

                <div class="form-group">
                    <label for="priority"><i class="fas fa-exclamation-circle"></i> Priority Level</label>
                    <select id="priority" name="priority" class="form-control">
                        <option value="normal">Normal - Regular consultation</option>
                        <option value="high">High - Urgent, need early attention</option>
                        <option value="emergency">Emergency - Severe symptoms</option>
                    </select>
                    <p class="small text-muted" style="margin-top:4px;"><i class="fas fa-info-circle"></i> Priority is also auto-calculated based on your symptoms and profile. Higher priority is applied automatically if applicable.</p>
                </div>

                <div id="autoPriorityInfo" style="display:none;" class="flash flash-info">
                    <!-- Auto-priority info shown if applicable -->
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-outline" id="backToStep3">
                        <i class="fas fa-arrow-left"></i> Back
                    </button>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-check-circle"></i> Confirm Appointment
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>

<style>
.quick-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
.quick-tag {
    padding: 6px 14px; border-radius: 20px; font-size: 13px; cursor: pointer;
    background: var(--bg-secondary); border: 1px solid var(--border); transition: all 0.2s;
    user-select: none;
}
.quick-tag:hover { background: var(--primary-light); border-color: var(--primary); color: var(--primary); }
.quick-tag.added { background: var(--primary); color: #fff; border-color: var(--primary); }
.doctor-select-card .recommend-badge {
    position: absolute; top: 10px; right: 10px; background: linear-gradient(135deg, #10b981, #059669);
    color: #fff; font-size: 11px; padding: 3px 10px; border-radius: 12px; font-weight: 600;
    z-index: 2;
}
.doctor-select-card .female-pref-badge {
    position: absolute; top: 10px; left: 10px; background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    color: #fff; font-size: 11px; padding: 3px 10px; border-radius: 12px; font-weight: 600;
    z-index: 2;
}
.doctor-select-card { position: relative; }
.match-score { font-size: 12px; color: var(--success); font-weight: 600; margin-top: 4px; }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const symptomInput = document.getElementById('symptomInput');
    const symptomsHidden = document.getElementById('symptoms_hidden');
    const dateInput = document.getElementById('appointment_date');
    const slotsContainer = document.getElementById('slotsContainer');
    const slotInput = document.getElementById('slot_id');
    const findDoctorsBtn = document.getElementById('findDoctorsBtn');
    const toStep3 = document.getElementById('toStep3');
    const toStep4 = document.getElementById('toStep4');
    const backToStep1 = document.getElementById('backToStep1');
    const backToStep2 = document.getElementById('backToStep2');
    const backToStep3 = document.getElementById('backToStep3');
    const steps = document.querySelectorAll('.step');
    const sections = {
        step1: document.getElementById('step1'),
        step2: document.getElementById('step2'),
        step3: document.getElementById('step3'),
        step4: document.getElementById('step4')
    };

    const preferFemaleCheck = document.getElementById('prefer_female_doctor_check');
    let selectedDoctor = null;

    // Quick tags
    document.querySelectorAll('.quick-tag').forEach(tag => {
        tag.addEventListener('click', function() {
            const text = this.dataset.tag;
            const current = symptomInput.value.trim();
            if (current.toLowerCase().includes(text.toLowerCase())) {
                this.classList.toggle('added');
                return;
            }
            symptomInput.value = current ? current + ', ' + text : text;
            this.classList.add('added');
        });
    });

    // Step navigation
    function showStep(num) {
        Object.values(sections).forEach(s => s.classList.add('hidden'));
        sections['step' + num].classList.remove('hidden');
        steps.forEach(s => {
            s.classList.remove('active', 'completed');
            const sNum = parseInt(s.dataset.step);
            if (sNum < num) s.classList.add('completed');
            if (sNum === num) s.classList.add('active');
        });
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Step 1 → Step 2: Find doctors
    findDoctorsBtn.addEventListener('click', async function() {
        const symptoms = symptomInput.value.trim();
        if (!symptoms) {
            alert('Please describe your symptoms before continuing.');
            return;
        }

        symptomsHidden.value = symptoms;
        findDoctorsBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Finding best doctors...';
        findDoctorsBtn.disabled = true;

        try {
            const res = await fetch(`/appointments/recommend-doctors?symptoms=${encodeURIComponent(symptoms)}`);
            const data = await res.json();

            if (data.doctors && data.doctors.length > 0) {
                const grid = document.getElementById('doctorRecommendations');
                const preferFemale = preferFemaleCheck ? preferFemaleCheck.checked : false;

                // Sort: if prefer female, put female doctors first among same-score doctors
                let sortedDoctors = [...data.doctors];
                if (preferFemale) {
                    sortedDoctors.sort((a, b) => {
                        if (b.matchScore !== a.matchScore) return b.matchScore - a.matchScore;
                        const aFemale = (a.gender || '').toLowerCase() === 'female' ? 1 : 0;
                        const bFemale = (b.gender || '').toLowerCase() === 'female' ? 1 : 0;
                        return bFemale - aFemale;
                    });
                }

                grid.innerHTML = sortedDoctors.map((doc, idx) => {
                    const isRecommended = doc.matchScore > 0;
                    const isFemaleDoc = (doc.gender || '').toLowerCase() === 'female';
                    const showFemaleBadge = preferFemale && isFemaleDoc;

                    return `
                    <label class="doctor-select-card" for="doctor_${doc.id}">
                        <input type="radio" id="doctor_${doc.id}" name="doctor_id" value="${doc.id}"
                            data-doctor-name="${doc.name}"
                            data-specialization="${doc.specialization}"
                            data-gender="${doc.gender || ''}"
                            required>
                        ${isRecommended ? '<span class="recommend-badge"><i class="fas fa-star"></i> Recommended</span>' : ''}
                        ${showFemaleBadge ? '<span class="female-pref-badge"><i class="fas fa-venus"></i> Preferred</span>' : ''}
                        <div class="doctor-select-inner">
                            <div class="doctor-select-avatar">
                                <i class="fas fa-user-md"></i>
                            </div>
                            <h4>${doc.name}</h4>
                            <span class="badge badge-primary">${doc.specialization}</span>
                            <p class="small">${doc.qualification || ''}</p>
                            <p class="small text-muted">${doc.experience_years || 0} years experience</p>
                            ${doc.gender ? '<p class="small text-muted"><i class="fas fa-' + (doc.gender === 'Female' ? 'venus' : 'mars') + '"></i> ' + doc.gender + '</p>' : ''}
                            ${isRecommended && doc.matchedKeywords && doc.matchedKeywords.length > 0 ?
                                '<div class="match-score"><i class="fas fa-check-circle"></i> Matches: ' + doc.matchedKeywords.join(', ') + '</div>' : ''}
                        </div>
                        <div class="doctor-select-check">
                            <i class="fas fa-check-circle"></i>
                        </div>
                    </label>`;
                }).join('');

                // Re-attach radio listeners
                attachDoctorListeners();
            }

            showStep(2);
        } catch (err) {
            console.error(err);
            alert('Failed to find doctors. Please try again.');
        } finally {
            findDoctorsBtn.innerHTML = '<i class="fas fa-search"></i> Find Best Doctor';
            findDoctorsBtn.disabled = false;
        }
    });

    function attachDoctorListeners() {
        const radios = document.querySelectorAll('input[name="doctor_id"]');
        radios.forEach(radio => {
            radio.addEventListener('change', function() {
                selectedDoctor = {
                    id: this.value,
                    name: this.dataset.doctorName,
                    specialization: this.dataset.specialization,
                    gender: this.dataset.gender
                };
                toStep3.disabled = false;
                document.querySelectorAll('.doctor-select-card').forEach(c => c.classList.remove('selected'));
                this.closest('.doctor-select-card').classList.add('selected');
            });
        });
    }

    // Initial attach
    attachDoctorListeners();

    // Step navigation buttons
    backToStep1.addEventListener('click', () => showStep(1));

    toStep3.addEventListener('click', () => {
        // Reset date and slot on re-entry
        showStep(3);
    });
    backToStep2.addEventListener('click', () => showStep(2));

    toStep4.addEventListener('click', () => {
        const dateVal = dateInput.value;
        const dateFormatted = new Date(dateVal).toLocaleDateString('en-IN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        const slotText = document.querySelector('.slot-card.selected')?.querySelector('.slot-time')?.textContent || '';
        const symptomsText = symptomInput.value.trim();

        document.getElementById('bookingSummary').innerHTML = `
            <div class="summary-row"><strong>Doctor:</strong> ${selectedDoctor.name}</div>
            <div class="summary-row"><strong>Specialization:</strong> ${selectedDoctor.specialization}</div>
            <div class="summary-row"><strong>Date:</strong> ${dateFormatted}</div>
            <div class="summary-row"><strong>Time Slot:</strong> ${slotText}</div>
            <div class="summary-row"><strong>Symptoms:</strong> ${symptomsText}</div>
        `;

        // Sync symptoms to hidden field
        symptomsHidden.value = symptomsText;
        showStep(4);
    });
    backToStep3.addEventListener('click', () => showStep(3));

    // Fetch slots on date change
    dateInput.addEventListener('change', async function() {
        if (!selectedDoctor || !this.value) return;

        slotsContainer.innerHTML = '<div class="loading"><i class="fas fa-spinner fa-spin"></i> Loading available slots...</div>';
        toStep4.disabled = true;
        slotInput.value = '';

        try {
            const res = await fetch(`/appointments/slots/${selectedDoctor.id}/${this.value}`);
            const data = await res.json();

            if (data.slots && data.slots.length > 0) {
                let html = '<div class="slots-grid">';
                data.slots.forEach(slot => {
                    const start = slot.start_time.substring(0, 5);
                    const end = slot.end_time.substring(0, 5);
                    html += `
                        <div class="slot-card" data-slot-id="${slot.id}" onclick="selectSlot(this, ${slot.id})">
                            <div class="slot-time">${start} - ${end}</div>
                            <div class="slot-info">${slot.remaining} spots left</div>
                        </div>
                    `;
                });
                html += '</div>';
                slotsContainer.innerHTML = html;
            } else {
                slotsContainer.innerHTML = `
                    <div class="empty-state small-state">
                        <i class="fas fa-calendar-times"></i>
                        <p>No available slots on this date. The doctor may not be available or all slots are full.</p>
                        <p class="text-muted">Try selecting a different date.</p>
                    </div>
                `;
            }
        } catch (err) {
            slotsContainer.innerHTML = '<div class="flash flash-error">Failed to load slots. Please try again.</div>';
        }
    });

    // Select slot
    window.selectSlot = function(el, slotId) {
        document.querySelectorAll('.slot-card').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
        slotInput.value = slotId;
        toStep4.disabled = false;
    };
});
</script>

<%- include('../partials/footer') %>
