<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="page-header page-header-dark">
    <div class="container">
        <h1><i class="fas fa-calendar-check"></i> Appointments</h1>
        <p>Manage all patient appointments</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <!-- Filters -->
        <div class="card mb-2">
            <div class="card-body">
                <form action="/admin/appointments" method="GET" class="filter-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Status</label>
                            <select name="status" class="form-control">
                                <option value="">All Statuses</option>
                                <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                <option value="confirmed" <%= filters.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                                <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
                                <option value="cancelled" <%= filters.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Date</label>
                            <input type="date" name="date" class="form-control" value="<%= filters.date %>">
                        </div>
                        <div class="form-group">
                            <label>Doctor</label>
                            <select name="doctor_id" class="form-control">
                                <option value="">All Doctors</option>
                                <% doctors.forEach(doc => { %>
                                    <option value="<%= doc.id %>" <%= filters.doctor_id == doc.id ? 'selected' : '' %>><%= doc.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group" style="align-self: flex-end;">
                            <button type="submit" class="btn btn-primary">Filter</button>
                            <a href="/admin/appointments" class="btn btn-outline">Clear</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Appointments Table -->
        <div class="card">
            <div class="card-body">
                <% if (appointments && appointments.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Patient</th>
                                    <th>Doctor</th>
                                    <th>Date</th>
                                    <th>Symptoms</th>
                                    <th>Priority</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% appointments.forEach((apt, idx) => { %>
                                    <tr>
                                        <td><%= idx + 1 %></td>
                                        <td>
                                            <a href="/admin/patients/<%= apt.patient_id %>"><strong><%= apt.patient_name %></strong></a>
                                            <br><span class="text-muted small"><%= apt.roll_number || '' %></span>
                                        </td>
                                        <td><%= apt.doctor_name %><br><span class="text-muted small"><%= apt.specialization %></span></td>
                                        <td><%= new Date(apt.appointment_date).toLocaleDateString('en-IN') %></td>
                                        <td><%= apt.symptoms ? apt.symptoms.substring(0, 40) + (apt.symptoms.length > 40 ? '...' : '') : 'N/A' %></td>
                                        <td>
                                            <span class="badge badge-<%= apt.priority === 'emergency' ? 'danger' : apt.priority === 'high' ? 'warning' : 'info' %>">
                                                <%= apt.priority %>
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge badge-<%= apt.status === 'confirmed' ? 'success' : apt.status === 'pending' ? 'warning' : apt.status === 'completed' ? 'info' : 'danger' %>">
                                                <%= apt.status %>
                                            </span>
                                        </td>
                                        <td>
                                            <div class="action-buttons">
                                                <% if (apt.status === 'pending') { %>
                                                    <form action="/admin/appointments/<%= apt.id %>/status" method="POST" style="display:inline;">
                                                        <input type="hidden" name="status" value="confirmed">
                                                        <input type="hidden" name="notes" value="">
                                                        <button type="submit" class="btn btn-sm btn-success" title="Confirm"><i class="fas fa-check"></i></button>
                                                    </form>
                                                <% } %>
                                                <% if (apt.status !== 'completed' && apt.status !== 'cancelled') { %>
                                                    <a href="/admin/prescriptions/add?appointment_id=<%= apt.id %>" class="btn btn-sm btn-primary" title="Add Prescription"><i class="fas fa-file-prescription"></i></a>
                                                    <form action="/admin/appointments/<%= apt.id %>/status" method="POST" style="display:inline;">
                                                        <input type="hidden" name="status" value="cancelled">
                                                        <input type="hidden" name="notes" value="Cancelled by admin">
                                                        <button type="submit" class="btn btn-sm btn-danger" title="Cancel" onclick="return confirm('Cancel this appointment?')"><i class="fas fa-times"></i></button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <p class="text-muted">Showing <%= appointments.length %> appointment(s)</p>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fas fa-calendar-times"></i>
                        <h3>No appointments found</h3>
                        <p>No appointments match the selected filters.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
