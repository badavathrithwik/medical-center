<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="page-header page-header-dark">
    <div class="container">
        <div class="page-header-row">
            <div>
                <h1><i class="fas fa-file-prescription"></i> Prescriptions</h1>
                <p>All patient prescriptions</p>
            </div>
            <a href="/admin/prescriptions/add" class="btn btn-primary"><i class="fas fa-plus"></i> New Prescription</a>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <% if (prescriptions && prescriptions.length > 0) { %>
            <div class="prescriptions-list">
                <% prescriptions.forEach(rx => { %>
                    <div class="card mb-1">
                        <div class="card-body">
                            <div class="prescription-row">
                                <div class="rx-main">
                                    <h4><%= rx.diagnosis %></h4>
                                    <div class="rx-meta">
                                        <span><i class="fas fa-user"></i> <%= rx.patient_name %> (<%= rx.roll_number %>)</span>
                                        <span><i class="fas fa-user-md"></i> <%= rx.doctor_name %></span>
                                        <span><i class="fas fa-calendar"></i> <%= new Date(rx.created_at).toLocaleDateString('en-IN') %></span>
                                    </div>
                                    <div class="rx-medicines-inline">
                                        <% const meds = typeof rx.medicines === 'string' ? JSON.parse(rx.medicines) : rx.medicines; %>
                                        <% if (meds && meds.length > 0) { %>
                                            <% meds.forEach(med => { %>
                                                <span class="medicine-tag"><%= med.name %></span>
                                            <% }) %>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="rx-actions">
                                    <a href="/admin/prescriptions/<%= rx.id %>" class="btn btn-sm btn-outline"><i class="fas fa-eye"></i> View</a>
                                    <a href="/admin/patients/<%= rx.patient_id %>" class="btn btn-sm btn-outline"><i class="fas fa-user"></i> Patient</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <i class="fas fa-file-prescription"></i>
                <h3>No prescriptions yet</h3>
                <p>Prescriptions will appear here once created.</p>
                <a href="/admin/prescriptions/add" class="btn btn-primary"><i class="fas fa-plus"></i> Create First Prescription</a>
            </div>
        <% } %>
    </div>
</section>

<%- include('../partials/footer') %>
