<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<section class="page-header page-header-dark">
    <div class="container">
        <h1><i class="fas fa-user"></i> <%= patient.name %></h1>
        <p><%= patient.roll_number || '' %> | <%= patient.department || '' %> | <%= patient.email %></p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="patient-detail-grid">
            <!-- Patient Info -->
            <div class="card">
                <div class="card-header">
                    <h3><i class="fas fa-id-card"></i> Personal Information</h3>
                </div>
                <div class="card-body">
                    <div class="info-list">
                        <div class="info-item"><strong>Name:</strong> <%= patient.name %></div>
                        <div class="info-item"><strong>Email:</strong> <%= patient.email %></div>
                        <div class="info-item"><strong>Phone:</strong> <%= patient.phone || 'N/A' %></div>
                        <div class="info-item"><strong>Roll Number:</strong> <%= patient.roll_number || 'N/A' %></div>
                        <div class="info-item"><strong>Department:</strong> <%= patient.department || 'N/A' %></div>
                        <div class="info-item"><strong>Gender:</strong> <%= patient.gender || 'N/A' %></div>
                        <div class="info-item"><strong>Date of Birth:</strong> <%= patient.date_of_birth ? new Date(patient.date_of_birth).toLocaleDateString('en-IN') : 'N/A' %></div>
                        <div class="info-item"><strong>Category:</strong>
                            <span class="badge badge-<%= patient.user_type === 'faculty' ? 'primary' : patient.user_type === 'staff' ? 'info' : 'success' %>">
                                <%= (patient.user_type || 'student').charAt(0).toUpperCase() + (patient.user_type || 'student').slice(1) %>
                            </span>
                            <% if (patient.is_handicapped) { %>
                                <span class="badge badge-warning"><i class="fas fa-wheelchair"></i> PwD</span>
                            <% } %>
                        </div>
                        <div class="info-item"><strong>Registered:</strong> <%= new Date(patient.created_at).toLocaleDateString('en-IN') %></div>
                    </div>
                </div>
            </div>

            <!-- Medical Record -->
            <div class="card">
                <div class="card-header">
                    <h3><i class="fas fa-notes-medical"></i> Medical Record</h3>
                </div>
                <div class="card-body">
                    <% if (medicalRecord) { %>
                        <div class="info-list">
                            <div class="info-item"><strong>Blood Group:</strong> <%= medicalRecord.blood_group || 'N/A' %></div>
                            <div class="info-item"><strong>Height:</strong> <%= medicalRecord.height_cm ? medicalRecord.height_cm + ' cm' : 'N/A' %></div>
                            <div class="info-item"><strong>Weight:</strong> <%= medicalRecord.weight_kg ? medicalRecord.weight_kg + ' kg' : 'N/A' %></div>
                            <div class="info-item"><strong>Allergies:</strong> <%= medicalRecord.allergies || 'None reported' %></div>
                            <div class="info-item"><strong>Chronic Conditions:</strong> <%= medicalRecord.chronic_conditions || 'None reported' %></div>
                            <div class="info-item"><strong>Current Medications:</strong> <%= medicalRecord.current_medications || 'None' %></div>
                            <div class="info-item"><strong>Emergency Contact:</strong> <%= medicalRecord.emergency_contact_name || 'N/A' %> (<%= medicalRecord.emergency_contact_relation || '' %>) - <%= medicalRecord.emergency_contact_phone || '' %></div>
                        </div>
                    <% } else { %>
                        <p class="text-muted">No medical record on file.</p>
                    <% } %>

                    <!-- Update Medical Record Form -->
                    <details class="mt-2">
                        <summary class="btn btn-sm btn-outline"><i class="fas fa-edit"></i> Update Medical Record</summary>
                        <form action="/admin/patients/<%= patient.id %>/medical-record" method="POST" class="mt-1">
                            <div class="form-row">
                                <div class="form-group">
                                    <label>Blood Group</label>
                                    <select name="blood_group" class="form-control">
                                        <option value="">Select</option>
                                        <% ['A+','A-','B+','B-','AB+','AB-','O+','O-'].forEach(bg => { %>
                                            <option value="<%= bg %>" <%= medicalRecord && medicalRecord.blood_group === bg ? 'selected' : '' %>><%= bg %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Height (cm)</label>
                                    <input type="number" name="height_cm" class="form-control" step="0.1" value="<%= medicalRecord ? medicalRecord.height_cm || '' : '' %>">
                                </div>
                                <div class="form-group">
                                    <label>Weight (kg)</label>
                                    <input type="number" name="weight_kg" class="form-control" step="0.1" value="<%= medicalRecord ? medicalRecord.weight_kg || '' : '' %>">
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Allergies</label>
                                <textarea name="allergies" class="form-control" rows="2"><%= medicalRecord ? medicalRecord.allergies || '' : '' %></textarea>
                            </div>
                            <div class="form-group">
                                <label>Chronic Conditions</label>
                                <textarea name="chronic_conditions" class="form-control" rows="2"><%= medicalRecord ? medicalRecord.chronic_conditions || '' : '' %></textarea>
                            </div>
                            <div class="form-group">
                                <label>Current Medications</label>
                                <textarea name="current_medications" class="form-control" rows="2"><%= medicalRecord ? medicalRecord.current_medications || '' : '' %></textarea>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label>Emergency Contact Name</label>
                                    <input type="text" name="emergency_contact_name" class="form-control" value="<%= medicalRecord ? medicalRecord.emergency_contact_name || '' : '' %>">
                                </div>
                                <div class="form-group">
                                    <label>Emergency Contact Phone</label>
                                    <input type="text" name="emergency_contact_phone" class="form-control" value="<%= medicalRecord ? medicalRecord.emergency_contact_phone || '' : '' %>">
                                </div>
                                <div class="form-group">
                                    <label>Relation</label>
                                    <input type="text" name="emergency_contact_relation" class="form-control" value="<%= medicalRecord ? medicalRecord.emergency_contact_relation || '' : '' %>">
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Medical Record</button>
                        </form>
                    </details>
                </div>
            </div>
        </div>

        <!-- Complete Visit History -->
        <div class="card mt-2">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3><i class="fas fa-history"></i> Complete Visit History</h3>
                <div>
                    <span class="badge badge-info" style="font-size:14px;"><%= appointments ? appointments.length : 0 %> total visit(s)</span>
                    <a href="/admin/prescriptions/add?patient_id=<%= patient.id %>" class="btn btn-sm btn-primary" style="margin-left:8px;"><i class="fas fa-plus"></i> Add Prescription</a>
                </div>
            </div>
            <div class="card-body">
                <% if (appointments && appointments.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table" id="visitHistoryTable">
                            <thead>
                                <tr>
                                    <th style="width:110px;">Date</th>
                                    <th>Doctor Name</th>
                                    <th>Symptoms</th>
                                    <th>Diagnosis & Treatments Given</th>
                                    <th style="width:90px;">Priority</th>
                                    <th style="width:100px;">Status</th>
                                    <th style="width:80px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% appointments.forEach(apt => { %>
                                    <tr class="visit-row visit-<%= apt.status %>">
                                        <td>
                                            <strong><%= new Date(apt.appointment_date).toLocaleDateString('en-IN') %></strong>
                                        </td>
                                        <td>
                                            <strong><%= apt.doctor_name %></strong><br>
                                            <span class="text-muted small"><%= apt.specialization %></span>
                                        </td>
                                        <td>
                                            <div style="max-width:250px;">
                                                <%= apt.symptoms || 'N/A' %>
                                            </div>
                                        </td>
                                        <td>
                                            <% if (apt.diagnosis) { %>
                                                <div style="max-width:350px;">
                                                    <strong style="color:var(--primary);">Diagnosis:</strong> <%= apt.diagnosis %><br>
                                                    <% const meds = apt.medicines ? (typeof apt.medicines === 'string' ? JSON.parse(apt.medicines) : apt.medicines) : []; %>
                                                    <% if (meds && meds.length > 0) { %>
                                                        <strong style="color:var(--primary);">Medicines:</strong>
                                                        <ul style="margin:4px 0 4px 18px; padding:0; font-size:0.9em;">
                                                            <% meds.forEach(med => { %>
                                                                <li><%= med.name %> — <%= med.dosage %> (<%= med.frequency %>, <%= med.duration %>)</li>
                                                            <% }) %>
                                                        </ul>
                                                    <% } %>
                                                    <% if (apt.tests_recommended) { %>
                                                        <strong style="color:var(--primary);">Tests:</strong> <%= apt.tests_recommended %><br>
                                                    <% } %>
                                                    <% if (apt.rx_instructions) { %>
                                                        <strong style="color:var(--primary);">Instructions:</strong> <%= apt.rx_instructions %><br>
                                                    <% } %>
                                                    <% if (apt.follow_up_date) { %>
                                                        <strong style="color:var(--warning);">Follow-up:</strong> <%= new Date(apt.follow_up_date).toLocaleDateString('en-IN') %>
                                                    <% } %>
                                                </div>
                                            <% } else { %>
                                                <span class="text-muted">No prescription yet</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <span class="badge badge-<%= apt.priority === 'emergency' ? 'danger' : apt.priority === 'high' ? 'warning' : 'info' %>">
                                                <%= apt.priority || 'normal' %>
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge badge-<%= apt.status === 'confirmed' ? 'success' : apt.status === 'pending' ? 'warning' : apt.status === 'completed' ? 'info' : 'danger' %>">
                                                <%= apt.status %>
                                            </span>
                                        </td>
                                        <td>
                                            <% if (apt.status !== 'completed' && !apt.prescription_id) { %>
                                                <a href="/admin/prescriptions/add?appointment_id=<%= apt.id %>" class="btn btn-sm btn-outline" title="Add Prescription"><i class="fas fa-file-prescription"></i></a>
                                            <% } else if (apt.prescription_id) { %>
                                                <a href="/admin/prescriptions/<%= apt.prescription_id %>" class="btn btn-sm btn-outline" title="View Prescription"><i class="fas fa-eye"></i></a>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-state small-state">
                        <i class="fas fa-calendar-times"></i>
                        <p>No past visits found for this patient.</p>
                    </div>
                <% } %>
            </div>
        </div>
        <!-- All Prescriptions -->
        <div class="card mt-2">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3><i class="fas fa-file-medical"></i> All Prescriptions</h3>
                <span class="badge badge-info" style="font-size:14px;"><%= prescriptions ? prescriptions.length : 0 %> total prescription(s)</span>
            </div>
            <div class="card-body">
                <% if (prescriptions && prescriptions.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Date Issued</th>
                                    <th>Doctor</th>
                                    <th>Diagnosis</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% prescriptions.forEach(rx => { %>
                                    <tr>
                                        <td><strong><%= new Date(rx.created_at).toLocaleDateString('en-IN') %></strong></td>
                                        <td><%= rx.doctor_name %><br><span class="text-muted small"><%= rx.specialization %></span></td>
                                        <td><%= rx.diagnosis.substring(0, 50) %><%= rx.diagnosis.length > 50 ? '...' : '' %></td>
                                        <td>
                                            <a href="/admin/prescriptions/<%= rx.id %>" class="btn btn-sm btn-primary"><i class="fas fa-eye"></i> View</a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-state small-state">
                        <i class="fas fa-file-medical-alt"></i>
                        <p>No prescriptions found for this patient.</p>
                    </div>
                <% } %>
            </div>
        </div>

    </div>
</section>

<style>
.visit-row.visit-completed { border-left: 3px solid var(--success); }
.visit-row.visit-cancelled { border-left: 3px solid var(--danger); opacity: 0.7; }
.visit-row.visit-pending { border-left: 3px solid var(--warning); }
.visit-row.visit-confirmed { border-left: 3px solid var(--primary); }
</style>

<%- include('../partials/footer') %>
