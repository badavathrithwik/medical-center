<%- include('partials/header') %>
<%- include('partials/navbar') %>

<section class="page-header">
    <div class="container">
        <h1><i class="fas fa-hospital-alt"></i> Our Facilities</h1>
        <p>Modern healthcare facilities to serve the IIT Ropar campus community</p>
    </div>
</section>

<section class="section bg-light">
    <div class="container">
        <div class="card p-4 mb-4">
            <h2 class="mb-4">Contact Numbers</h2>
            <ul class="list-group">
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    Medical Centre Emergency/Pharmacy
                    <span class="badge badge-primary badge-pill">01881235193 (Available 24x7)</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    Medical Officer Main Campus
                    <span class="badge badge-primary badge-pill">01881235187</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    Medical Officer Ayurveda/Homeopathic
                    <span class="badge badge-primary badge-pill">01881235188</span>
                </li>
            </ul>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="facilities-grid">
            <div class="facility-card">
                <div class="facility-icon">
                    <i class="fas fa-stethoscope"></i>
                </div>
                <h3>General OPD</h3>
                <p>Outpatient department for general medical consultations, health check-ups, and treatment of common illnesses and minor injuries.</p>
            </div>

            <div class="facility-card">
                <div class="facility-icon">
                    <i class="fas fa-brain"></i>
                </div>
                <h3>Mental Health & Counseling</h3>
                <p>Confidential counseling and psychiatric services for stress, anxiety, depression, and other mental health concerns.</p>
            </div>

            <div class="facility-card">
                <div class="facility-icon">
                    <i class="fas fa-bone"></i>
                </div>
                <h3>Orthopedic Care</h3>
                <p>Specialized care for bone, joint, and muscle problems including sports injuries, fractures, and rehabilitation.</p>
            </div>

            <div class="facility-card">
                <div class="facility-icon">
                    <i class="fas fa-ambulance"></i>
                </div>
                <h3>Emergency Services</h3>
                <p>Round-the-clock emergency medical services with ambulance facility for campus and nearby hospital transfers.</p>
            </div>

            <div class="facility-card">
                <div class="facility-icon">
                    <i class="fas fa-pills"></i>
                </div>
                <h3>Pharmacy</h3>
                <p>In-house pharmacy dispensing prescribed medicines free of charge to registered students and staff.</p>
            </div>

            <div class="facility-card">
                <div class="facility-icon">
                    <i class="fas fa-vial"></i>
                </div>
                <h3>Basic Diagnostics</h3>
                <p>Basic laboratory tests, blood pressure monitoring, blood sugar testing, and other diagnostic services.</p>
            </div>

            <div class="facility-card">
                <div class="facility-icon">
                    <i class="fas fa-first-aid"></i>
                </div>
                <h3>First Aid</h3>
                <p>Immediate first aid treatment for injuries, wounds, burns, and other emergency situations on campus.</p>
            </div>

            <div class="facility-card">
                <div class="facility-icon">
                    <i class="fas fa-heartbeat"></i>
                </div>
                <h3>Health Checkups</h3>
                <p>Preventive health screening and routine check-ups to monitor and maintain your overall well-being.</p>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
