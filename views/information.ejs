<%- include('partials/header') %>
<%- include('partials/navbar') %>

<section class="page-header">
    <div class="container">
        <h1><i class="fas fa-info-circle"></i> Information</h1>
        <p>Important information about Medical Center services and policies</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="info-grid">
            <div class="info-card">
                <h3><i class="fas fa-id-card"></i> Eligibility</h3>
                <ul>
                    <li>All registered students of IIT Ropar</li>
                    <li>Faculty members and their families</li>
                    <li>Staff members and their dependents</li>
                    <li>Contractual workers (emergency only)</li>
                </ul>
            </div>

            <div class="info-card">
                <h3><i class="fas fa-clipboard-list"></i> How to Visit</h3>
                <ol>
                    <li>Book an appointment online or walk-in during OPD hours</li>
                    <li>Carry your Institute ID card</li>
                    <li>Visit the doctor at your scheduled time</li>
                    <li>Collect prescribed medicines from the pharmacy</li>
                </ol>
            </div>

            <div class="info-card">
                <h3><i class="fas fa-file-medical"></i> Documents Required</h3>
                <ul>
                    <li>Institute ID card (mandatory)</li>
                    <li>Previous medical records (if any)</li>
                    <li>Insurance card (if applicable)</li>
                    <li>Referral letter (for specialist consultation)</li>
                </ul>
            </div>

            <div class="info-card">
                <h3><i class="fas fa-exclamation-triangle"></i> Emergency Protocol</h3>
                <ul>
                    <li>Call emergency number: 01881-235193</li>
                    <li>Ambulance available 24/7 on campus</li>
                    <li>First aid available at the Medical Center</li>
                    <li>Referral to nearby hospitals for critical cases</li>
                </ul>
            </div>

            <div class="info-card">
                <h3><i class="fas fa-hospital"></i> Referral Hospitals</h3>
                <ul>
                    <li>Civil Hospital, Rupnagar</li>
                    <li>PGIMER, Chandigarh</li>
                    <li>GMC, Patiala</li>
                    <li>Fortis Hospital, Mohali</li>
                </ul>
            </div>

            <div class="info-card">
                <h3><i class="fas fa-shield-alt"></i> Insurance</h3>
                <ul>
                    <li>Group medical insurance for all students</li>
                    <li>Coverage includes hospitalization, surgery, and treatment</li>
                    <li>Claims processed through Medical Center</li>
                    <li>Contact admin for insurance queries</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
